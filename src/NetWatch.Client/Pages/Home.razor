@page "/"
@inject HttpClient Http
@using NetWatch.Core.Diagnostics

<PageTitle>NetWatch</PageTitle>

<h1>NetWatch</h1>

<p class="lede">Project foundation status</p>

@if (status is null)
{
    <p>Loading API status…</p>
}
else
{
    <dl>
        <dt>Database</dt>
        <dd>@status.Database</dd>
        <dt>Schema version</dt>
        <dd>@status.SchemaVersion</dd>
        <dt>NetFlow listener</dt>
        <dd><code>@status.NetFlowEndpoint/udp</code></dd>
        <dt>MikroTik configured</dt>
        <dd>@(status.MikroTikConfigured ? "Yes" : "No")</dd>
        <dt>Reporting timezone</dt>
        <dd>@status.ReportingTimezone</dd>
    </dl>
}

@code {
    private SystemStatusResponse? status;

    protected override async Task OnInitializedAsync()
    {
        status = await Http.GetFromJsonAsync<SystemStatusResponse>("api/status");
    }
}
