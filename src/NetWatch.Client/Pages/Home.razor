@page "/"
@inject HttpClient Http

<PageTitle>NetWatch Phase 0</PageTitle>

<h1>NetWatch</h1>

<p class="lede">Phase 0 technical spike console</p>

@if (status is null)
{
    <p>Loading API status…</p>
}
else
{
    <dl>
        <dt>Database</dt>
        <dd><code>@status.DatabasePath</code></dd>
        <dt>NetFlow listener</dt>
        <dd><code>@status.NetFlowEndpoint/udp</code></dd>
        <dt>MikroTik configured</dt>
        <dd>@(status.MikroTikConfigured ? "Yes" : "No")</dd>
    </dl>
}

<button class="primary-button" @onclick="RunSqliteProbe" disabled="@sqliteProbeRunning">
    Test persistent SQLite write
</button>

@if (sqliteResult is not null)
{
    <p class="success-message">
        Persisted write count: <strong>@sqliteResult.WriteCount</strong>
    </p>
}

@code {
    private SpikeStatus? status;
    private SqliteResult? sqliteResult;
    private bool sqliteProbeRunning;

    protected override async Task OnInitializedAsync()
    {
        status = await Http.GetFromJsonAsync<SpikeStatus>("api/spikes/status");
    }

    private async Task RunSqliteProbe()
    {
        sqliteProbeRunning = true;
        try
        {
            using var response = await Http.PostAsync("api/spikes/sqlite", null);
            response.EnsureSuccessStatusCode();
            sqliteResult = await response.Content.ReadFromJsonAsync<SqliteResult>();
        }
        finally
        {
            sqliteProbeRunning = false;
        }
    }

    private sealed record SpikeStatus(
        string Product,
        string DatabasePath,
        string NetFlowEndpoint,
        bool MikroTikConfigured);

    private sealed record SqliteResult(long WriteCount, DateTimeOffset UpdatedAtUtc, string DatabasePath);
}
