@page "/"
@inject HttpClient _http
@using NetWatch.Core.Diagnostics

<PageTitle>NetWatch</PageTitle>

<h1>NetWatch</h1>

<p class="lede">Project foundation status</p>

@if (_status is null)
{
    <p>Loading API status…</p>
}
else
{
    <dl>
        <dt>Database</dt>
        <dd>@_status.Database</dd>
        <dt>Schema version</dt>
        <dd>@_status.SchemaVersion</dd>
        <dt>NetFlow listener</dt>
        <dd><code>@_status.NetFlowEndpoint/udp</code></dd>
        <dt>MikroTik configured</dt>
        <dd>@(_status.MikroTikConfigured ? "Yes" : "No")</dd>
        <dt>Reporting timezone</dt>
        <dd>@_status.ReportingTimezone</dd>
    </dl>
}

@code {
    private SystemStatusResponse? _status;

    protected override async Task OnInitializedAsync()
    {
        _status = await _http.GetFromJsonAsync<SystemStatusResponse>("api/status");
    }
}
