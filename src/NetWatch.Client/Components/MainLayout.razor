@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject HttpClient _http
@using System.Globalization
@using System.Net.Http.Json
@using NetWatch.Core.Diagnostics

<div class="app-shell">
    <aside class="sidebar">
        <a class="brand" href="" aria-label="NetWatch dashboard">
            <span class="brand-mark" aria-hidden="true"><AppIcon Name="logo" /></span>
            <span>NetWatch</span>
        </a>

        <nav aria-label="Primary navigation">
            <NavLink href="" Match="NavLinkMatch.All">
                <span class="nav-symbol" aria-hidden="true"><AppIcon Name="dashboard" /></span>
                <span>Dashboard</span>
            </NavLink>
            <NavLink href="devices">
                <span class="nav-symbol" aria-hidden="true"><AppIcon Name="devices" /></span>
                <span>Devices</span>
            </NavLink>
        </nav>

    </aside>

    <div class="workspace">
        <header class="topbar">
            <span class="topbar-context">Self-hosted network monitor</span>
            <div class="topbar-meta">
                <span class="server-clock" title="Time in the configured reporting timezone">
                    <AppIcon Name="clock" />@ServerTimeText
                </span>
                <span class="system-status @SystemStatusClass" title="@SystemStatusTitle">
                    <AppIcon Name="status" />@SystemStatusText
                </span>
            </div>
        </header>
        <main class="content">
            @Body
        </main>
    </div>
</div>

@code {
    private readonly CancellationTokenSource _clockCancellation = new();
    private readonly PeriodicTimer _clockTimer = new(TimeSpan.FromSeconds(1));
    private DateTimeOffset? _serverTime;
    private DateTimeOffset _serverTimeReceivedAtUtc;
    private DateTimeOffset? _lastDataAtUtc;
    private string? _reportingTimezone;
    private Task? _clockTask;
    private int _clockTicks;
    private bool _isOnline;

    private string ServerTimeText => _serverTime is not { } serverTime ?
        "Server time unavailable" :
        $"{serverTime.Add(DateTimeOffset.UtcNow - _serverTimeReceivedAtUtc).ToString("d MMM yyyy HH:mm:ss", CultureInfo.InvariantCulture)} · {_reportingTimezone}";

    private string SystemStatusClass => _isOnline ? "online" : "offline";

    private string SystemStatusText => _isOnline ?
        $"Online · {DataFreshnessText}" :
        $"Offline · {DataFreshnessText}";

    private string SystemStatusTitle => _isOnline ?
        "NetWatch is reachable. Freshness is based on the latest collected data." :
        "NetWatch could not be reached during the latest status check.";

    private string DataFreshnessText
    {
        get
        {
            if (_lastDataAtUtc is not { } lastDataAtUtc)
            {
                return "Waiting for data";
            }

            var age = DateTimeOffset.UtcNow - lastDataAtUtc;
            if (age.TotalMinutes < 1)
            {
                return "Updated just now";
            }

            if (age.TotalHours < 1)
            {
                return $"Updated {Math.Max(1, (int)age.TotalMinutes)} min ago";
            }

            if (age.TotalDays < 1)
            {
                return $"Updated {Math.Max(1, (int)age.TotalHours)} hr ago";
            }

            return $"Updated {Math.Max(1, (int)age.TotalDays)} d ago";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await SynchronizeClockAsync();
        _clockTask = RunClockAsync();
    }

    private async Task RunClockAsync()
    {
        try
        {
            while (await _clockTimer.WaitForNextTickAsync(_clockCancellation.Token))
            {
                _clockTicks++;
                if (_clockTicks % 60 == 0)
                {
                    await SynchronizeClockAsync();
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) when (_clockCancellation.IsCancellationRequested)
        {
        }
    }

    private async Task SynchronizeClockAsync()
    {
        try
        {
            var status = await _http.GetFromJsonAsync<SystemStatusResponse>("api/status", _clockCancellation.Token);
            if (status is not null)
            {
                _isOnline = true;
                _serverTime = status.CurrentTime;
                _serverTimeReceivedAtUtc = DateTimeOffset.UtcNow;
                _reportingTimezone = status.ReportingTimezone;
            }
        }
        catch (HttpRequestException)
        {
            _isOnline = false;
            return;
        }

        try
        {
            var diagnostics = await _http.GetFromJsonAsync<CollectorDiagnosticsResponse>(
                "api/diagnostics",
                _clockCancellation.Token);
            if (diagnostics is not null)
            {
                _lastDataAtUtc = diagnostics.LastFlushAtUtc ?? diagnostics.LastFlowAtUtc;
            }
        }
        catch (HttpRequestException)
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        await _clockCancellation.CancelAsync();
        _clockTimer.Dispose();

        if (_clockTask is not null)
        {
            await _clockTask;
        }

        _clockCancellation.Dispose();
    }
}
